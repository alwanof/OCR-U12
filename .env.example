# Model & engine configuration — copy to .env and edit to swap models.
#   cp .env.example .env
# docker-compose reads this via ${VAR:-default} interpolation; missing file = defaults.
# After changing values: docker compose up -d (containers restart with new env).

# ── MinerU (layout, reading order, tables) ──────────────────────────────────
# Backend: pipeline (CPU-friendly, current) | vlm-auto-engine (GPU, higher accuracy)
MINERU_BACKEND=pipeline
# Device: cpu | cuda | cuda:0  (set cuda on the GPU server)
MINERU_DEVICE=cpu
MINERU_LANG=arabic
# ocr = force real OCR (Arabic PDF text layers are unreliable) | auto | txt
MINERU_METHOD=ocr
# Formula parsing hallucinates LaTeX from Arabic calligraphy — keep false for Arabic
MINERU_FORMULA=false
MINERU_TABLE=true

# ── Qari-OCR (Arabic recognition, hybrid engine) ────────────────────────────
# Current: 2B print-focused. Future upgrades (need more RAM/GPU):
#   NAMAA-Space/Qari-OCR-0.4.0-VL-4B-Instruct   (larger, ~9 GB bf16)
QARI_MODEL_ID=NAMAA-Space/Qari-OCR-v0.3-VL-2B-Instruct
QARI_MAX_NEW_TOKENS=512
QARI_REPETITION_PENALTY=1.15
QARI_RENDER_SCALE=2.8

# ── Field extraction (Ollama) ───────────────────────────────────────────────
# Pull the model first: docker compose exec ollama ollama pull <model>
# Upgrades: qwen3:8b (production), qwen3:14b (needs ~12 GB RAM)
EXTRACT_MODEL=qwen3:4b
EXTRACT_NUM_CTX=16384
EXTRACT_MAX_CHARS=12000
EXTRACT_TIMEOUT=900

# ── App ─────────────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=50
